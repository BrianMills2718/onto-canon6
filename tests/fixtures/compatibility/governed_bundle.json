{
  "surface": "governed_bundle",
  "description": "Schema contract for governed bundle export surface.",
  "models": {
    "GovernedWorkflowBundle": {
      "required_fields": [
        "workflow_id",
        "generated_at",
        "scope",
        "candidate_bundles",
        "summary"
      ],
      "field_types": {
        "workflow_id": "<class 'str'>",
        "generated_at": "<class 'str'>",
        "scope": "<class 'onto_canon6.surfaces.governed_bundle.GovernedBundleScope'>",
        "candidate_bundles": "tuple[onto_canon6.surfaces.governed_bundle.GovernedCandidateBundle, ...]",
        "summary": "<class 'onto_canon6.surfaces.governed_bundle.GovernedWorkflowBundleSummary'>"
      }
    },
    "GovernedCandidateBundle": {
      "required_fields": [
        "candidate",
        "linked_proposals",
        "linked_overlay_applications",
        "artifact_links",
        "artifacts",
        "lineage_edges",
        "epistemic_status",
        "confidence",
        "superseded_by",
        "supersedes"
      ],
      "field_types": {
        "candidate": "<class 'onto_canon6.pipeline.models.CandidateAssertionRecord'>",
        "linked_proposals": "tuple[onto_canon6.pipeline.models.ProposalRecord, ...]",
        "linked_overlay_applications": "tuple[onto_canon6.pipeline.models.OverlayApplicationRecord, ...]",
        "artifact_links": "tuple[onto_canon6.artifacts.models.CandidateArtifactLinkRecord, ...]",
        "artifacts": "tuple[onto_canon6.artifacts.models.ArtifactRecord, ...]",
        "lineage_edges": "tuple[onto_canon6.artifacts.models.ArtifactLineageEdge, ...]",
        "epistemic_status": "typing.Literal['active', 'superseded']",
        "confidence": "onto_canon6.extensions.epistemic.models.ConfidenceAssessmentRecord | None",
        "superseded_by": "onto_canon6.extensions.epistemic.models.SupersessionRecord | None",
        "supersedes": "tuple[onto_canon6.extensions.epistemic.models.SupersessionRecord, ...]"
      }
    }
  }
}